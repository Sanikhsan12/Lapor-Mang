# Copy file ini menjadi .env dan sesuaikan nilainya
# Copy this file to .env and fill in the values

PORT=5000

# Azure Database for PostgreSQL (BUKAN container db lokal)
DATABASE_URL=postgresql://DB_USER:DB_PASSWORD@DB_HOST.postgres.database.azure.com:5432/DB_NAME?sslmode=require&schema=public

JWT_SECRET=ganti-dengan-secret-yang-kuat-dan-panjang

# CORS: IP Publik VM + port frontend
CORS_ORIGIN=http://IP_VM_LO:8080

# Azure Blob Storage (untuk penyimpanan foto laporan)
AZURE_STORAGE_CONNECTION_STRING=DefaultEndpointsProtocol=https;AccountName=NAMA_STORAGE;AccountKey=KEY_DARI_AZURE_PORTAL;EndpointSuffix=core.windows.net
AZURE_STORAGE_CONTAINER_NAME=nama-container-lo
